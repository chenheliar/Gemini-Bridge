{
  "name": "gemini-node-bridge",
  "productName": "Gemini Bridge",
  "version": "1.0.0",
  "private": true,
  "description": "Gemini Bridge desktop app with OpenAI-compatible API and Chinese management interface",
  "type": "module",
  "main": "dist/electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:web\"",
    "dev:desktop": "concurrently -k \"npm:dev:server\" \"npm:dev:web\" \"npm:dev:desktop-shell\"",
    "dev:desktop-shell": "npm run build:electron && cross-env ELECTRON_RENDERER_URL=http://127.0.0.1:5173 ELECTRON_SERVER_URL=http://127.0.0.1:3100 electron .",
    "dev:server": "tsx watch src/server.ts",
    "dev:web": "vite --config vite.config.ts",
    "build": "npm run build:server && npm run build:web && npm run build:electron",
    "build:server": "tsc -p tsconfig.json",
    "build:web": "tsc -b web/tsconfig.json && vite build --config vite.config.ts",
    "build:electron": "tsc -p electron/tsconfig.json",
    "lint:web": "eslint --config web/eslint.config.js web/src",
    "start": "node dist/server.js",
    "start:desktop": "npm run build && electron .",
    "pack:win": "npm run build && electron-builder --win nsis --publish never",
    "pack:mac": "npm run build && electron-builder --mac --publish never"
  },
  "keywords": [
    "gemini",
    "openai-compatible",
    "express",
    "bridge"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.13.1",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "http-proxy-agent": "^7.0.2",
    "https-proxy-agent": "^7.0.6",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0",
    "set-cookie-parser": "^2.7.2",
    "socks-proxy-agent": "^8.0.5",
    "uuid": "^13.0.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/set-cookie-parser": "^2.4.10",
    "@vitejs/plugin-react": "^6.0.1",
    "cross-env": "^10.1.0",
    "concurrently": "^9.2.1",
    "electron": "^37.4.0",
    "electron-builder": "^26.0.12",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1"
  },
  "build": {
    "appId": "com.chenz.geminibridge",
    "productName": "Gemini Bridge",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/assets/**/*",
      "package.json",
      "README.md",
      "README.zh-CN.md",
      "cookies.example.json"
    ],
    "extraMetadata": {
      "main": "dist/electron/main.cjs"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "electron/assets/app-icon.ico",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity",
      "icon": "electron/assets/app-icon.png",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Gemini Bridge"
    }
  }
}
